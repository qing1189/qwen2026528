# === Qwen-2API 配置 ===

# Qwen 账号（邮箱:密码），多个用逗号分隔
# QWEN_ACCOUNTS=email1:password1,email2:password2

# 或直接提供 JWT 令牌，多个用逗号分隔
# QWEN_TOKENS=eyJ...,eyJ...

# 多 API Key（逗号分隔，也可通过管理面板动态添加）
# API_KEYS=sk-key1,sk-key2,sk-key3

# 兼容旧配置：单个 API Key（会自动合并到 API_KEYS）
# API_KEY=sk-your-key

# 管理面板独立密码（与 API Key 分离）
# ADMIN_PASSWORD=your-admin-password

# 服务端口（Docker 模式下容器内部固定 3000，此变量控制宿主机映射端口）
PORT=3000
